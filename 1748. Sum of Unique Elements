class Solution {
    public int sumOfUnique(int[] nums) {
     int s=0;
     for(int i=0;i<nums.length-1;i++){
        if(nums[i]!=-1){
            int temp=nums[i];
        for(int j=i+1;j<nums.length;j++){
            if(temp==nums[j]){
                nums[i]=-1;
                nums[j]=-1;
            }
        }
     }  
     
    }
    for(int i=0;i<nums.length;i++){
        if(nums[i]!=-1){
            s+=nums[i];
        }
    }
    return s;
}
}
