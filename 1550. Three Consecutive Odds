class Solution {
    public boolean threeConsecutiveOdds(int[] arr) {
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]%2!=0){
            int c=1;
            for(int j=i+1;j<arr.length;j++){
                if(arr[j]%2==0){
                    break;
                }
                else{
                    c++;
                }
            }
            if(c>=3){
                return true;
            }
        }
        }
        return false;
    }
}
