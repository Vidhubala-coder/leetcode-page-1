class Solution {
    public int findLucky(int[] arr) {
        int max = -1;

        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == -1) continue;

            int c = 1;

            for (int j = i + 1; j < arr.length; j++) {
                if (arr[j] != -1 && arr[i] == arr[j]) {
                    c++;
                    arr[j] = -1;
                }
            }

            if (c == arr[i]) {
                max = Math.max(max, arr[i]);
            }
        }

        return max;
    }
}
